{
  "name": "ikaros-infra",
  "description": "ikaros-infra",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node scripts/postinstall.mjs",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "upgrade": "pnpm up -r && pnpm up -r -w",
    "lint:fix": "eslint \"packages/**/*.{js,jsx,ts,tsx,vue}\" --fix && prettier --write \"packages/**/*.{js,jsx,ts,tsx,vue}\""
  },
  "license": "MIT",
  "devDependencies": {
    "@ikaros-cli/eslint-plugin": "workspace:*",
    "@ikaros-cli/prettier-config": "workspace:*",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}