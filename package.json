{
  "name": "ikaros-infra",
  "description": "ikaros-infra",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node scripts/postinstall.mjs",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version && node scripts/postinstall.mjs",
    "changeset:publish": "changeset publish",
    "upgrade": "pnpm up -r && pnpm up -r -w",
    "lint:fix": "eslint \"packages/**/*.{js,jsx,ts,tsx,vue}\" --fix && prettier --write \"packages/**/*.{js,jsx,ts,tsx,vue}\""
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@ikaros-cli/eslint-plugin": "workspace:*",
    "@ikaros-cli/prettier-config": "workspace:*",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}